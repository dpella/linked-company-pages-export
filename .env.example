# Copy to .env and fill in.
# Values come from your LinkedIn Developer app: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Must exactly match a Redirect URL configured under your app's Auth tab.
LINKEDIN_REDIRECT_URI=http://localhost:8000/callback
# Your LinkedIn organization ID (the numeric ID of your company page).
LINKEDIN_ORG_ID=76457805

# Optional: bypass the OAuth flow by pasting a token from
# https://www.linkedin.com/developers/tools/oauth/token-generator
# LINKEDIN_ACCESS_TOKEN=
